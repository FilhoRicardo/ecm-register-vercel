# Public Supabase URL for browser-side features. VITE_ variables are baked into the client bundle.
VITE_SUPABASE_URL=

# Public Supabase publishable key for browser-side features. VITE_ variables are baked into the client bundle.
VITE_SUPABASE_PUBLISHABLE_KEY=

# Server-only Supabase project URL for Vercel API routes. Do not expose this with a VITE_ prefix.
SUPABASE_URL=

# Server-only Supabase service role key for Vercel API routes. Keep this in Vercel environment variables only.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only bearer token required by backup and monthly-usage sync API routes. Never use a VITE_ prefix.
BACKUP_UPLOAD_TOKEN=

# Optional server-only Supabase Storage bucket for backups. Leave blank to use the API default.
SUPABASE_BACKUP_BUCKET=

# Optional server-only Supabase Storage key prefix for backups. Leave blank to use the API default.
SUPABASE_BACKUP_PREFIX=
